<?xml version="1.0" encoding="utf-8"?>
<!--
  Ollama is reached over plain HTTP. Cleartext is allowed only to loopback
  addresses (where Ollama actually runs, via Termux) — not globally — so a
  future non-localhost host in settings won't silently work over cleartext.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
